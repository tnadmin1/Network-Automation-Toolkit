# ============================================================
# network-automation-toolkit — .gitignore
# ============================================================
# This file tells git what NOT to track.
# Security-sensitive and environment-specific files are excluded.
# ============================================================


# --- Python ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# --- Virtual Environments ------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# --- CRITICAL: Credentials and Secrets ----------------------
# These files must NEVER be committed to version control.
# In cleared/federal environments, committing creds is a
# reportable security incident.
inventory/credentials.env
inventory/*.env
.env
.env.*
!.env.example
!credentials.env.example
*.vault
.vault_pass
vault_pass.txt
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*.pub


# --- Ansible -------------------------------------------------
*.retry
.ansible/
collections/
roles/external/


# --- Logs ----------------------------------------------------
*.log
logs/
*.log.*


# --- Generated Runtime Output --------------------------------
# Reports and backups are generated at runtime.
# Commit specific reports deliberately — don't auto-track all.
reports/*.csv
reports/*.html
reports/*.json
# Backups are large and device-specific — exclude from tracking
backups/*.cfg
backups/*.txt
backups/*.log
# Uncomment below to re-include backups in tracking:
# !backups/.gitkeep


# --- Testing -------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/


# --- IDE and Editor Artifacts --------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace


# --- OS Artifacts -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# --- Terraform (future integration) -------------------------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl


# --- Miscellaneous ------------------------------------------
*.bak
*.tmp
*.orig
*.pid
.cache/

# Phase 3 diff reports (may contain config data)
reports/*.md
reports/*.txt

# Terraform
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
crash.log
*.tfvars
