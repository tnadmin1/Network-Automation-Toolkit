# ============================================================
# .env.example — credential template
# ============================================================
# Copy this file to .env and fill in your real device credentials:
#     cp .env.example .env
#
# The .env file is excluded from git by .gitignore and is NEVER committed.
# This .env.example IS committed, so other engineers (and future you)
# know which variables the project expects.
# ============================================================

NET_USERNAME=your_username
NET_PASSWORD=your_password

# Optional — only needed if your device requires 'enable' / privileged
# mode for commands like 'show running-config'. Leave blank if your
# login user is already privilege level 15 (most labs and sandboxes are).
NET_SECRET=
